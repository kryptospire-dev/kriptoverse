# =============================================================================
# MNTC Rewards Bot Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# =============================================================================

# =============================================================================
# REQUIRED CREDENTIALS
# =============================================================================

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# Firebase Realtime Database URL
FIREBASE_DB_URL=https://your-project.firebaseio.com

# Firebase Credentials (JSON string) - For production deployment
# FIREBASE_CREDENTIALS={"type":"service_account","project_id":"..."}

# Firebase Credentials Path - For local development
FIREBASE_CRED_PATH=firebase-credentials.json

# =============================================================================
# CHANNEL CONFIGURATION
# =============================================================================

# Telegram channel username (with @)
MINATI_CHANNEL=@Minatirewards

# Telegram channel ID (get using @username_to_id_bot)
MINATI_CHANNEL_ID=-1002975509146

# =============================================================================
# WEBHOOK CONFIGURATION (Recommended for Production)
# =============================================================================

# Enable webhook mode (true/false)
# Webhooks are faster and more efficient than polling
WEBHOOK_ENABLED=false

# Your public webhook URL (e.g., https://yourdomain.com)
# Required when WEBHOOK_ENABLED=true
WEBHOOK_URL=

# Webhook path (endpoint on your server)
WEBHOOK_PATH=/webhook

# Webhook port
WEBHOOK_PORT=8443

# Webhook secret token (auto-generated if not set)
WEBHOOK_SECRET=

# =============================================================================
# REDIS CONFIGURATION (Recommended for Production)
# =============================================================================

# Enable Redis for distributed caching (true/false)
# Highly recommended for multi-instance deployments
REDIS_ENABLED=false

# Redis connection URL
# Format: redis://host:port or redis://user:password@host:port
REDIS_URL=redis://localhost:6379

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================

# Number of concurrent HTTP connections to Telegram API
# Default: 32 (good for 50K-100K users)
# Increase for higher load (max: 100)
CONNECTION_POOL_SIZE=32

# Maximum concurrent update processing
# Default: 100
# Higher values = better throughput but more memory
MAX_CONCURRENT_UPDATES=100

# Request timeout in seconds
# Default: 30
REQUEST_TIMEOUT=30

# Cache TTL (Time To Live) in seconds
# Default: 300 (5 minutes)
# Lower = more API calls but fresher data
# Higher = fewer API calls but stale data
CACHE_TTL=300

# =============================================================================
# MONITORING
# =============================================================================

# Prometheus metrics port
# Metrics available at http://localhost:8000/metrics
METRICS_PORT=8000

# =============================================================================
# PERFORMANCE RECOMMENDATIONS BY USER COUNT
# =============================================================================
#
# 1,000-10,000 users (Development/Testing):
#   CONNECTION_POOL_SIZE=8
#   MAX_CONCURRENT_UPDATES=50
#   REDIS_ENABLED=false
#   WEBHOOK_ENABLED=false
#
# 10,000-50,000 users (Small Production):
#   CONNECTION_POOL_SIZE=16
#   MAX_CONCURRENT_UPDATES=100
#   REDIS_ENABLED=true
#   WEBHOOK_ENABLED=true
#
# 50,000-200,000 users (Medium Production):
#   CONNECTION_POOL_SIZE=32
#   MAX_CONCURRENT_UPDATES=200
#   REDIS_ENABLED=true
#   WEBHOOK_ENABLED=true
#   Use multiple bot instances with load balancer
#
# 200,000+ users (Large Production):
#   CONNECTION_POOL_SIZE=64
#   MAX_CONCURRENT_UPDATES=500
#   REDIS_ENABLED=true (with Redis Cluster)
#   WEBHOOK_ENABLED=true
#   Use auto-scaling with 5-10 bot instances
#   Consider Firebase Blaze plan
#
# =============================================================================
